# Maintainer: Kalowave <dev@kalowave.com>
pkgname=jtoon-bin
pkgver=0.1.0
pkgrel=1
pkgdesc="CLI tool to convert between JSON and TOON formats"
arch=('x86_64')
url="https://github.com/Kalowave/jtoon"
license=('MIT')
provides=('jtoon')
conflicts=('jtoon')
source=("https://github.com/Kalowave/jtoon/releases/download/v${pkgver}/jtoon-x86_64-unknown-linux-gnu.tar.gz")
sha256sums=('SKIP')

package() {
    install -Dm755 jtoon "${pkgdir}/usr/bin/jtoon"
    install -Dm644 <(curl -sL "https://raw.githubusercontent.com/Kalowave/jtoon/v${pkgver}/LICENSE") "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"
}
